{
  "manifest_version": 3,
  "name": "Focus Mode Activator",
  "version": "0.7.2",
  "description": "Block browser notifications with a single toolbar click.",
  "permissions": ["storage", "contentSettings", "alarms"],
  "commands": {
    "toggle-focus-mode": {
      "suggested_key": {
        "default": "Alt+Shift+F",
        "mac": "Alt+Shift+F"
      },
      "description": "Toggle Focus Mode on or off"
    }
  },
  "action": {
    "default_popup": "popup/popup.html",
    "default_title": "Focus Mode Activator",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "options_page": "options/options.html",
  "background": {
    "service_worker": "background/service-worker.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content/page-patch.js"],
      "run_at": "document_start",
      "world": "MAIN"
    },
    {
      "matches": ["<all_urls>"],
      "js": ["content/content-script.js"],
      "run_at": "document_start"
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
